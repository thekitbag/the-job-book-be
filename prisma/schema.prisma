generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  role      UserRole @default(PILOT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  jobs            Job[]
  reviewDecisions ReviewDecision[]

  @@map("users")
}

enum UserRole {
  PILOT
  INTERNAL
}

model Job {
  id                   String    @id @default(uuid())
  ownerUserId          String
  title                String
  jobType              String
  status               JobStatus @default(ACTIVE)
  roughLocationOrLabel String?
  notes                String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  owner           User             @relation(fields: [ownerUserId], references: [id])
  rawNotes        RawNote[]
  candidateFacts  CandidateFact[]
  reviewDecisions ReviewDecision[]
  memoryItems     MemoryItem[]
  queueItems      QueueItem[]

  @@map("jobs")
}

enum JobStatus {
  ACTIVE
  COMPLETED
  ARCHIVED
}

model RawNote {
  id           String         @id @default(uuid())
  jobId        String
  clientNoteId String
  capturedAt   DateTime
  uploadedAt   DateTime       @default(now())
  mimeType     String
  durationMs   Int?
  sizeBytes    Int
  serverStatus NoteStatus     @default(UPLOADED)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  job            Job             @relation(fields: [jobId], references: [id])
  audioObject    AudioObject?
  transcripts    Transcript[]
  candidateFacts CandidateFact[]

  @@unique([jobId, clientNoteId])
  @@map("raw_notes")
}

enum NoteStatus {
  UPLOADED
  QUEUED
  TRANSCRIBING
  TRANSCRIBED
  EXTRACTING
  EXTRACTED
  RECONCILING
  DONE
  FAILED
}

model AudioObject {
  id         String   @id @default(uuid())
  noteId     String   @unique
  storageKey String   @unique
  bucket     String
  mimeType   String
  sizeBytes  Int
  createdAt  DateTime @default(now())

  note RawNote @relation(fields: [noteId], references: [id])

  @@map("audio_objects")
}

model Transcript {
  id                   String           @id @default(uuid())
  noteId               String
  revision             Int              @default(1)
  status               TranscriptStatus @default(PENDING)
  text                 String?
  language             String?
  confidence           Float?
  provider             String?
  model                String?
  requestSchemaVersion String?
  providerResponseId   String?
  retryCount           Int              @default(0)
  errorCode            String?
  errorMessage         String?
  startedAt            DateTime?
  completedAt          DateTime?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  extractionStatus        ExtractionStatus?
  extractionProvider      String?
  extractionModel         String?
  extractionSchemaVersion String?
  extractionErrorCode     String?
  extractionErrorMessage  String?
  extractionStartedAt     DateTime?
  extractionCompletedAt   DateTime?

  note           RawNote         @relation(fields: [noteId], references: [id])
  candidateFacts CandidateFact[]

  @@map("transcripts")
}

enum TranscriptStatus {
  PENDING
  TRANSCRIBING
  COMPLETED
  FAILED
}

enum ExtractionStatus {
  PENDING
  EXTRACTING
  COMPLETED
  FAILED
}

enum FactType {
  ORDERED_MATERIAL
  USED_MATERIAL
  LEFTOVER_MATERIAL
  SUPPLIER_DELIVERY_NOTE
  CUSTOMER_CHANGE
  WATCH_OUT
  UNCLEAR
}

enum CandidateFactStatus {
  DRAFT
  UNCLEAR
  CONFIRMED
  CORRECTED
  REJECTED
  SUPERSEDED
}

enum ConfidenceLabel {
  HIGH
  MEDIUM
  LOW
}

model CandidateFact {
  id                      String              @id @default(uuid())
  jobId                   String
  sourceNoteId            String
  sourceTranscriptId      String
  factType                FactType
  status                  CandidateFactStatus @default(DRAFT)
  summary                 String
  materialName            String?
  quantity                String?
  unit                    String?
  supplierName            String?
  deliveryTiming          String?
  locationOrUse           String?
  confidenceLabel         ConfidenceLabel
  confidenceReason        String
  uncertaintyFlags        String[]
  costAmount              String?
  costCurrency            String?
  costQualifier           String?
  totalCostAmount         String?
  extractionProvider      String?
  extractionModel         String?
  extractionSchemaVersion String?
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt

  job             Job              @relation(fields: [jobId], references: [id])
  sourceNote      RawNote          @relation(fields: [sourceNoteId], references: [id])
  transcript      Transcript       @relation(fields: [sourceTranscriptId], references: [id])
  reviewDecisions ReviewDecision[]
  memoryItems     MemoryItem[]

  @@map("candidate_facts")
}

enum ReviewDecisionAction {
  CONFIRM
  CORRECT
  REJECT
  CONFIRM_SECTION
  ADD_MISSING
  QUEUE_CONFIRM
  QUEUE_CORRECT
  QUEUE_DISMISS
}

model ReviewDecision {
  id              String               @id @default(uuid())
  jobId           String
  decidedBy       String
  action          ReviewDecisionAction
  candidateFactId        String?
  sectionKey             String?
  reason                 String?
  sourceCandidateFactIds String[]             @default([])
  createdAt              DateTime             @default(now())

  job           Job            @relation(fields: [jobId], references: [id])
  user          User           @relation(fields: [decidedBy], references: [id])
  candidateFact CandidateFact? @relation(fields: [candidateFactId], references: [id])
  memoryItems   MemoryItem[]

  @@map("review_decisions")
}

model MemoryItem {
  id                    String   @id @default(uuid())
  jobId                 String
  reviewDecisionId      String
  sourceCandidateFactId String?
  memoryType            FactType
  isManual              Boolean  @default(false)
  summary               String
  materialName          String?
  quantity              String?
  unit                  String?
  supplierName          String?
  deliveryTiming        String?
  locationOrUse         String?
  costAmount            String?
  costCurrency          String?
  costQualifier         String?
  totalCostAmount       String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  job            Job            @relation(fields: [jobId], references: [id])
  reviewDecision ReviewDecision @relation(fields: [reviewDecisionId], references: [id])
  sourceFact     CandidateFact? @relation(fields: [sourceCandidateFactId], references: [id])

  @@map("memory_items")
}

model QueueItem {
  id                     String   @id @default(uuid())
  jobId                  String
  sectionKey             String
  kind                   String
  status                 String   @default("draft")
  reviewLabel            String
  timeLabel              String?
  summary                String
  proposedMemory         Json
  confidenceLabel        String   @default("medium")
  uncertaintyFlags       String[]
  sourceCandidateFactIds String[]
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  job Job @relation(fields: [jobId], references: [id])

  @@index([jobId])
  @@map("queue_items")
}
