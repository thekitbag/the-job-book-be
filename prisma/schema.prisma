generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  role         UserRole @default(PILOT)
  passwordHash String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  jobs                Job[]
  reviewDecisions     ReviewDecision[]
  passwordResetTokens PasswordResetToken[]
  uploadedPhotos      JobPhoto[]
  supportAuditEvents  SupportAuditEvent[]

  @@map("users")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("password_reset_tokens")
}

enum UserRole {
  PILOT
  INTERNAL
}

model Job {
  id                    String    @id @default(uuid())
  ownerUserId           String
  title                 String
  jobType               String
  status                JobStatus @default(PLANNING)
  roughLocationOrLabel  String?
  notes                 String?
  customerTotalAmount   String?
  customerTotalCurrency String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  owner            User                @relation(fields: [ownerUserId], references: [id])
  rawNotes         RawNote[]
  candidateFacts   CandidateFact[]
  reviewDecisions  ReviewDecision[]
  memoryItems      MemoryItem[]
  queueItems       QueueItem[]
  budgetCategories JobBudgetCategory[]
  photos           JobPhoto[]
  payments         JobPayment[]

  @@map("jobs")
}

enum JobStatus {
  PLANNING
  STARTED
  FINISHED
  ARCHIVED
}

model RawNote {
  id           String         @id @default(uuid())
  jobId        String
  clientNoteId String
  capturedAt   DateTime
  uploadedAt   DateTime       @default(now())
  mimeType     String
  durationMs   Int?
  sizeBytes    Int
  serverStatus NoteStatus     @default(UPLOADED)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  job            Job             @relation(fields: [jobId], references: [id])
  audioObject    AudioObject?
  transcripts    Transcript[]
  candidateFacts CandidateFact[]
  linkedPhotos   JobPhoto[]

  @@unique([jobId, clientNoteId])
  @@map("raw_notes")
}

enum NoteStatus {
  UPLOADED
  QUEUED
  TRANSCRIBING
  TRANSCRIBED
  EXTRACTING
  EXTRACTED
  RECONCILING
  DONE
  FAILED
}

model AudioObject {
  id         String   @id @default(uuid())
  noteId     String   @unique
  storageKey String   @unique
  bucket     String
  mimeType   String
  sizeBytes  Int
  createdAt  DateTime @default(now())

  note RawNote @relation(fields: [noteId], references: [id])

  @@map("audio_objects")
}

model Transcript {
  id                   String           @id @default(uuid())
  noteId               String
  revision             Int              @default(1)
  status               TranscriptStatus @default(PENDING)
  text                 String?
  language             String?
  confidence           Float?
  provider             String?
  model                String?
  requestSchemaVersion String?
  providerResponseId   String?
  retryCount           Int              @default(0)
  errorCode            String?
  errorMessage         String?
  startedAt            DateTime?
  completedAt          DateTime?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  extractionStatus        ExtractionStatus?
  extractionProvider      String?
  extractionModel         String?
  extractionSchemaVersion String?
  extractionErrorCode     String?
  extractionErrorMessage  String?
  extractionStartedAt     DateTime?
  extractionCompletedAt   DateTime?

  note           RawNote         @relation(fields: [noteId], references: [id])
  candidateFacts CandidateFact[]

  @@map("transcripts")
}

enum TranscriptStatus {
  PENDING
  TRANSCRIBING
  COMPLETED
  FAILED
}

enum ExtractionStatus {
  PENDING
  EXTRACTING
  COMPLETED
  FAILED
}

enum FactType {
  ORDERED_MATERIAL
  USED_MATERIAL
  LEFTOVER_MATERIAL
  RETURNED_MATERIAL
  SUPPLIER_DELIVERY_NOTE
  CUSTOMER_CHANGE
  WATCH_OUT
  LABOUR
  GENERAL_NOTE
  UNCLEAR
}

enum CandidateFactStatus {
  DRAFT
  UNCLEAR
  CONFIRMED
  CORRECTED
  REJECTED
  SUPERSEDED
}

enum ConfidenceLabel {
  HIGH
  MEDIUM
  LOW
}

model CandidateFact {
  id                      String              @id @default(uuid())
  jobId                   String
  sourceNoteId            String
  sourceTranscriptId      String
  factType                FactType
  status                  CandidateFactStatus @default(DRAFT)
  summary                 String
  materialName            String?
  quantity                String?
  unit                    String?
  supplierName            String?
  deliveryTiming          String?
  locationOrUse           String?
  confidenceLabel         ConfidenceLabel
  confidenceReason        String
  uncertaintyFlags        String[]
  costAmount              String?
  costCurrency            String?
  costQualifier           String?
  totalCostAmount         String?
  labourHours             String?
  labourPerson            String?
  labourTask              String?
  happenedAt              DateTime?
  extractionProvider      String?
  extractionModel         String?
  extractionSchemaVersion String?
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt

  job             Job              @relation(fields: [jobId], references: [id])
  sourceNote      RawNote          @relation(fields: [sourceNoteId], references: [id])
  transcript      Transcript       @relation(fields: [sourceTranscriptId], references: [id])
  reviewDecisions ReviewDecision[]
  memoryItems     MemoryItem[]

  @@map("candidate_facts")
}

enum ReviewDecisionAction {
  CONFIRM
  CORRECT
  REJECT
  CONFIRM_SECTION
  ADD_MISSING
  QUEUE_CONFIRM
  QUEUE_CORRECT
  QUEUE_DISMISS
}

model ReviewDecision {
  id              String               @id @default(uuid())
  jobId           String
  decidedBy       String
  action          ReviewDecisionAction
  candidateFactId        String?
  sectionKey             String?
  reason                 String?
  sourceCandidateFactIds String[]             @default([])
  createdAt              DateTime             @default(now())

  job           Job            @relation(fields: [jobId], references: [id])
  user          User           @relation(fields: [decidedBy], references: [id])
  candidateFact CandidateFact? @relation(fields: [candidateFactId], references: [id])
  memoryItems   MemoryItem[]

  @@map("review_decisions")
}

model MemoryItem {
  id                    String   @id @default(uuid())
  jobId                 String
  reviewDecisionId      String
  sourceCandidateFactId String?
  memoryType            FactType
  isManual              Boolean  @default(false)
  summary               String
  materialName          String?
  quantity              String?
  unit                  String?
  supplierName          String?
  deliveryTiming        String?
  locationOrUse         String?
  costAmount            String?
  costCurrency          String?
  costQualifier         String?
  totalCostAmount       String?
  labourHours           String?
  labourPerson          String?
  labourTask            String?
  happenedAt            DateTime?
  unresolvedFlags       String[] @default([])
  budgetCategoryId      String?
  isRemoved             Boolean   @default(false)
  removedAt             DateTime?
  removedByUserId       String?
  removedReason         String?
  // Returned materials: a RETURNED_MATERIAL item records the returned quantity
  // (quantity/unit), merchant (supplierName), and — separate from spend cost
  // fields — a trusted refund. returnedFromMemoryItemId is a soft string link
  // back to the source Left over item (no FK; v1 traceability only).
  returnedFromMemoryItemId String?
  refundAmount             String?
  refundCurrency           String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  job            Job                @relation(fields: [jobId], references: [id])
  reviewDecision ReviewDecision     @relation(fields: [reviewDecisionId], references: [id])
  sourceFact     CandidateFact?     @relation(fields: [sourceCandidateFactId], references: [id])
  budgetCategory JobBudgetCategory? @relation(fields: [budgetCategoryId], references: [id])
  linkedPhotos   JobPhoto[]

  @@index([jobId, budgetCategoryId])
  @@index([jobId, isRemoved])
  @@map("memory_items")
}

model JobBudgetCategory {
  id             String   @id @default(uuid())
  jobId          String
  name           String
  budgetAmount   String?
  budgetCurrency String?
  sortOrder      Int      @default(0)
  isArchived     Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  job         Job          @relation(fields: [jobId], references: [id])
  memoryItems MemoryItem[]

  @@index([jobId, sortOrder])
  @@map("job_budget_categories")
}

model JobPhoto {
  id                 String   @id @default(uuid())
  jobId              String
  uploadedByUserId   String
  descriptor         String?
  storageKey         String   @unique
  bucket             String
  mimeType           String
  sizeBytes          Int
  linkedNoteId       String?
  linkedMemoryItemId String?
  isDeleted          Boolean   @default(false)
  deletedAt          DateTime?
  deletedByUserId    String?
  uploadedAt         DateTime @default(now())
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  job              Job         @relation(fields: [jobId], references: [id])
  uploadedBy       User        @relation(fields: [uploadedByUserId], references: [id])
  linkedNote       RawNote?    @relation(fields: [linkedNoteId], references: [id])
  linkedMemoryItem MemoryItem? @relation(fields: [linkedMemoryItemId], references: [id])

  @@index([jobId, uploadedAt])
  @@index([jobId, linkedNoteId])
  @@index([jobId, linkedMemoryItemId])
  @@index([jobId, isDeleted])
  @@map("job_photos")
}

model JobPayment {
  id        String    @id @default(uuid())
  jobId     String
  amount    String
  currency  String    @default("GBP")
  paidAt    DateTime
  note      String?
  reference String?
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  job Job @relation(fields: [jobId], references: [id])

  @@index([jobId, paidAt])
  @@index([jobId, isDeleted])
  @@map("job_payments")
}

model SupportAuditEvent {
  id           String   @id @default(uuid())
  adminUserId  String
  targetUserId String?
  targetJobId  String?
  action       String
  metadata     Json?
  createdAt    DateTime @default(now())

  adminUser User @relation(fields: [adminUserId], references: [id])

  @@index([adminUserId, createdAt])
  @@index([targetJobId, createdAt])
  @@map("support_audit_events")
}

model QueueItem {
  id                     String   @id @default(uuid())
  jobId                  String
  sectionKey             String
  kind                   String
  status                 String   @default("draft")
  reviewLabel            String
  timeLabel              String?
  summary                String
  proposedMemory         Json
  confidenceLabel        String   @default("medium")
  uncertaintyFlags       String[]
  sourceCandidateFactIds String[]
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  job Job @relation(fields: [jobId], references: [id])

  @@index([jobId])
  @@map("queue_items")
}
