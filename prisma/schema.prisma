generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  role      UserRole @default(PILOT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  jobs            Job[]
  reviewDecisions ReviewDecision[]
  tidyUpDecisions TidyUpDecision[]

  @@map("users")
}

enum UserRole {
  PILOT
  INTERNAL
}

model Job {
  id                   String    @id @default(uuid())
  ownerUserId          String
  title                String
  jobType              String
  status               JobStatus @default(ACTIVE)
  roughLocationOrLabel String?
  notes                String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  owner           User             @relation(fields: [ownerUserId], references: [id])
  rawNotes        RawNote[]
  candidateFacts  CandidateFact[]
  reviewDecisions ReviewDecision[]
  memoryItems     MemoryItem[]
  tidyUpRuns      TidyUpRun[]
  tidyUpItems     TidyUpItem[]
  tidyUpDecisions TidyUpDecision[]

  @@map("jobs")
}

enum JobStatus {
  ACTIVE
  COMPLETED
  ARCHIVED
}

model RawNote {
  id           String         @id @default(uuid())
  jobId        String
  clientNoteId String
  capturedAt   DateTime
  uploadedAt   DateTime       @default(now())
  mimeType     String
  durationMs   Int?
  sizeBytes    Int
  serverStatus NoteStatus     @default(UPLOADED)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  job            Job             @relation(fields: [jobId], references: [id])
  audioObject    AudioObject?
  transcripts    Transcript[]
  candidateFacts CandidateFact[]

  @@unique([jobId, clientNoteId])
  @@map("raw_notes")
}

enum NoteStatus {
  UPLOADED
  QUEUED
  TRANSCRIBING
  TRANSCRIBED
  EXTRACTING
  EXTRACTED
  RECONCILING
  DONE
  FAILED
}

model AudioObject {
  id         String   @id @default(uuid())
  noteId     String   @unique
  storageKey String   @unique
  bucket     String
  mimeType   String
  sizeBytes  Int
  createdAt  DateTime @default(now())

  note RawNote @relation(fields: [noteId], references: [id])

  @@map("audio_objects")
}

model Transcript {
  id                   String           @id @default(uuid())
  noteId               String
  revision             Int              @default(1)
  status               TranscriptStatus @default(PENDING)
  text                 String?
  language             String?
  confidence           Float?
  provider             String?
  model                String?
  requestSchemaVersion String?
  providerResponseId   String?
  retryCount           Int              @default(0)
  errorCode            String?
  errorMessage         String?
  startedAt            DateTime?
  completedAt          DateTime?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  extractionStatus        ExtractionStatus?
  extractionProvider      String?
  extractionModel         String?
  extractionSchemaVersion String?
  extractionErrorCode     String?
  extractionErrorMessage  String?
  extractionStartedAt     DateTime?
  extractionCompletedAt   DateTime?

  note           RawNote         @relation(fields: [noteId], references: [id])
  candidateFacts CandidateFact[]

  @@map("transcripts")
}

enum TranscriptStatus {
  PENDING
  TRANSCRIBING
  COMPLETED
  FAILED
}

enum ExtractionStatus {
  PENDING
  EXTRACTING
  COMPLETED
  FAILED
}

enum FactType {
  ORDERED_MATERIAL
  USED_MATERIAL
  LEFTOVER_MATERIAL
  SUPPLIER_DELIVERY_NOTE
  CUSTOMER_CHANGE
  WATCH_OUT
  UNCLEAR
}

enum CandidateFactStatus {
  DRAFT
  UNCLEAR
  CONFIRMED
  CORRECTED
  REJECTED
  SUPERSEDED
}

enum ConfidenceLabel {
  HIGH
  MEDIUM
  LOW
}

model CandidateFact {
  id                      String              @id @default(uuid())
  jobId                   String
  sourceNoteId            String
  sourceTranscriptId      String
  factType                FactType
  status                  CandidateFactStatus @default(DRAFT)
  summary                 String
  materialName            String?
  quantity                String?
  unit                    String?
  supplierName            String?
  deliveryTiming          String?
  locationOrUse           String?
  confidenceLabel         ConfidenceLabel
  confidenceReason        String
  uncertaintyFlags        String[]
  extractionProvider      String?
  extractionModel         String?
  extractionSchemaVersion String?
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt

  job             Job              @relation(fields: [jobId], references: [id])
  sourceNote      RawNote          @relation(fields: [sourceNoteId], references: [id])
  transcript      Transcript       @relation(fields: [sourceTranscriptId], references: [id])
  reviewDecisions ReviewDecision[]
  memoryItems     MemoryItem[]

  @@map("candidate_facts")
}

enum ReviewDecisionAction {
  CONFIRM
  CORRECT
  REJECT
  CONFIRM_SECTION
  ADD_MISSING
}

model ReviewDecision {
  id              String               @id @default(uuid())
  jobId           String
  decidedBy       String
  action          ReviewDecisionAction
  candidateFactId String?
  sectionKey      String?
  reason          String?
  createdAt       DateTime             @default(now())

  job           Job            @relation(fields: [jobId], references: [id])
  user          User           @relation(fields: [decidedBy], references: [id])
  candidateFact CandidateFact? @relation(fields: [candidateFactId], references: [id])
  memoryItems   MemoryItem[]

  @@map("review_decisions")
}

model MemoryItem {
  id                    String   @id @default(uuid())
  jobId                 String
  reviewDecisionId      String?  // set for per-note review decisions; null for tidy-up decisions
  tidyUpDecisionId      String?  // set for tidy-up decisions; null for per-note review decisions
  sourceCandidateFactId String?
  memoryType            FactType
  isManual              Boolean  @default(false)
  summary               String
  materialName          String?
  quantity              String?
  unit                  String?
  supplierName          String?
  deliveryTiming        String?
  locationOrUse         String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  job            Job             @relation(fields: [jobId], references: [id])
  reviewDecision ReviewDecision? @relation(fields: [reviewDecisionId], references: [id])
  sourceFact     CandidateFact?  @relation(fields: [sourceCandidateFactId], references: [id])

  @@map("memory_items")
}

// ── Story 8: End-Of-Day Tidy-Up ───────────────────────────────────────────────

enum TidyUpItemKind {
  SINGLE
  DUPLICATE_GROUP
  CONTRADICTION
  UNCLEAR_PROMPT
}

enum TidyUpItemStatus {
  DRAFT
  CONFIRMED
  CORRECTED
  REJECTED
  LEFT_UNCONFIRMED
}

enum TidyUpDecisionAction {
  CONFIRM
  CORRECT
  REJECT
  LEAVE_UNCONFIRMED
}

// One tidy-up pass for a job+day. Multiple runs may exist if forceRefresh is used.
model TidyUpRun {
  id        String   @id @default(uuid())
  jobId     String
  localDate String   // YYYY-MM-DD as submitted by the client
  status    String   @default("ready") // ready | failed
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  job   Job          @relation(fields: [jobId], references: [id])
  items TidyUpItem[]

  @@index([jobId, localDate])
  @@map("tidy_up_runs")
}

// One reviewable item within a tidy-up run, representing one or more source candidate facts.
model TidyUpItem {
  id                     String           @id @default(uuid())
  tidyUpRunId            String
  jobId                  String
  sectionKey             String
  kind                   TidyUpItemKind
  status                 TidyUpItemStatus @default(DRAFT)
  reviewLabel            String
  summary                String
  proposedMemory         Json
  confidenceLabel        String           @default("medium")
  uncertaintyFlags       String[]
  sourceCandidateFactIds String[]
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt

  tidyUpRun TidyUpRun       @relation(fields: [tidyUpRunId], references: [id])
  job       Job             @relation(fields: [jobId], references: [id])
  decisions TidyUpDecision[]

  @@map("tidy_up_items")
}

// Audit record for a Mike decision on one tidy-up item.
// sourceCandidateFactIds preserves all source fact links for multi-source memory items.
model TidyUpDecision {
  id                     String               @id @default(uuid())
  tidyUpItemId           String
  jobId                  String
  decidedBy              String
  action                 TidyUpDecisionAction
  correctedFields        Json?
  reason                 String?
  memoryItemId           String?              // set after memory item created; null for reject/leave
  sourceCandidateFactIds String[]
  createdAt              DateTime             @default(now())

  tidyUpItem TidyUpItem @relation(fields: [tidyUpItemId], references: [id])
  job        Job        @relation(fields: [jobId], references: [id])
  user       User       @relation(fields: [decidedBy], references: [id])

  @@map("tidy_up_decisions")
}
