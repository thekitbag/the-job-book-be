# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/jobbook_dev

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# ── Auth ──────────────────────────────────────────────────────────────────────
# Pilot user seeded in the database
PILOT_USER_ID=00000000-0000-0000-0000-000000000001

# Pilot passcode for POST /api/auth/pilot-login
PILOT_PASSCODE=change-me

# Secret for signing session cookies. Use a long random string in production.
SESSION_COOKIE_SECRET=dev-secret-change-in-production

# ── CORS / Cookie ─────────────────────────────────────────────────────────────
# Production: FRONTEND_ORIGIN=https://thejobbook.app
# Local dev: http://localhost:5173 (or your LAN address for phone testing)
FRONTEND_ORIGIN=http://localhost:5173

# Production only — leave unset in local dev
# COOKIE_DOMAIN=.thejobbook.app

# Legacy alias kept for backward compat (use FRONTEND_ORIGIN going forward)
# CORS_ORIGIN=http://localhost:5173

# ── Audio storage ─────────────────────────────────────────────────────────────
# local  — writes to LOCAL_AUDIO_DIR. Use for local dev.
# r2     — Cloudflare R2 via S3-compatible API. Use in production.
AUDIO_STORAGE_PROVIDER=local
LOCAL_AUDIO_DIR=./audio-store

# Cloudflare R2 (required when AUDIO_STORAGE_PROVIDER=r2)
# R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=

# ── AI providers ──────────────────────────────────────────────────────────────
# fake  — deterministic, no API key. Default for local dev and CI.
# openai — calls OpenAI. Required for production.
# TRANSCRIPTION_PROVIDER=openai
# EXTRACTION_PROVIDER=openai
# OPENAI_API_KEY=

# ── Render service settings (reference — configure in Render dashboard) ───────
# Build command:  npm ci && npm run db:generate && npm run build
# Start command:  npm run db:migrate:deploy && npm start
# Health check:   /health
# Auto-deploy:    enabled from main
